# Copy to /etc/sov-explorer.env with mode 0600 only after these DNS names have
# A/AAAA records pointing to the corresponding relay and valid TLS certificates.
# Do not point two names at one node and call it redundancy.

SOVEREIGN_MAINNET_RPCS=https://relay-ny.sovxus.org/rpc,https://relay-sf.sovxus.org/rpc

# One testnet relay is known today. Add a second URL only after a distinct node,
# host, chain-id pin, and genesis pin have been independently verified.
SOVEREIGN_TESTNET_RPCS=https://relay-testnet-1.sovxus.org/rpc

REQUIRE_TLS_RELAYS=1
CORS_ORIGIN=https://sovxus.org

# Keep `all` for one-process deployments. Split deployments use exactly one
# `ingest` writer and read-only `serve` processes sharing the local WAL archive.
EXPLORER_ROLE=all
ARCHIVE_DIR=/var/lib/sovereign-explorer
# Set a high-entropy value if /metrics is reachable outside the monitoring network.
METRICS_TOKEN=
